datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model PublicReview {
  id             String   @id @default(uuid())
  username       String
  profilePicture String?
  rating         Int      // 1 to 5 stars
  review         String
  createdAt      DateTime @default(now())
}
